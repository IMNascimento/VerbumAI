# ================================================================
#  verbumAI — Configuração
#  Copie para .env e preencha os valores
# ================================================================

# ── LLM Provider ─────────────────────────────────────────────────
# Opções: claude | openai | ollama
VERBUM_PROVIDER=claude

# ── API Keys ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Modelos ──────────────────────────────────────────────────────
VERBUM_CLAUDE_MODEL=claude-opus-4-6
VERBUM_OPENAI_MODEL=gpt-4o
VERBUM_OLLAMA_MODEL=llama3.2
VERBUM_OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding (roda sempre local) ────────────────────────────────
VERBUM_EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# ── RAG ──────────────────────────────────────────────────────────
VERBUM_TOP_K_RETRIEVAL=20
VERBUM_TOP_K_CONTEXT=8

# ── Banco vetorial ───────────────────────────────────────────────
VERBUM_DB_PATH=data/chroma_db
VERBUM_BIBLE_PATH=data/bible_acf.json
